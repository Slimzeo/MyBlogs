BLOG_PORT=8081
BLOG_BIND_ADDRESS=127.0.0.1
BLOG_GIN_MODE=release
BLOG_DB_DRIVER=sqlite
BLOG_DB_DSN='data/blog.db?_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)&_pragma=foreign_keys(1)'
BLOG_SESSION_SECRET=generate-a-random-value-at-least-32-bytes
BLOG_COOKIE_SECURE=false
BLOG_ADMIN_USERNAME=replace-with-your-admin-username
BLOG_ADMIN_EMAIL=replace-with-your-email
BLOG_ADMIN_INITIAL_PASSWORD=replace-with-a-strong-password
BLOG_UPLOAD_DIR=data/upload
BLOG_DB_MAX_OPEN_CONNS=100
BLOG_DB_MAX_IDLE_CONNS=20
BLOG_DB_CONN_MAX_LIFETIME_MIN=30
BLOG_HIT_FLUSH_EVERY=100
BLOG_RATE_LIMIT_RPS=200
BLOG_RATE_LIMIT_BURST=400
BLOG_READ_TIMEOUT_SEC=15
BLOG_WRITE_TIMEOUT_SEC=30
BLOG_SHUTDOWN_TIMEOUT_SEC=10
