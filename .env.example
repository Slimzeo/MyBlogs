PORT=8081
DB_DRIVER=sqlite
DB_DSN='data/blog.db?_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)&_pragma=foreign_keys(1)'
SESSION_SECRET=generate-a-random-value-at-least-32-bytes
COOKIE_SECURE=false
ADMIN_USERNAME=replace-with-your-admin-username
ADMIN_EMAIL=replace-with-your-email
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-password
UPLOAD_DIR=data/upload
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MIN=30
HIT_FLUSH_EVERY=100
RATE_LIMIT_RPS=200
RATE_LIMIT_BURST=400
READ_TIMEOUT_SEC=15
WRITE_TIMEOUT_SEC=30
SHUTDOWN_TIMEOUT_SEC=10
